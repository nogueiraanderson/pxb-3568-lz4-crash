[mysqld]
pxc_encrypt_cluster_traffic = OFF
innodb_buffer_pool_size      = 256M
innodb_log_file_size         = 128M
innodb_flush_log_at_trx_commit = 0

# Force xtrabackup-v2 SST method (default on PXC 8.0)
wsrep_sst_method = xtrabackup-v2

[sst]
encrypt = 0

[xtrabackup]
# This is the trigger for PXB-3568.
# LZ4 compression with default chunk-size hits the boundary condition
# in LZ4_compressBound (LZ4 issue #1374). The buffer allocated by
# ds_compress_lz4.cc is chunk_size bytes, but LZ4_compressBound returns
# chunk_size + 16 for inputs near 64KB. When the compressed output
# exceeds the undersized buffer, LZ4_compress_default returns 0 and
# xtrabackup aborts with Signal 6.
compress     = lz4
# 65534 = just under 64KB, maximizes chance of hitting the boundary.
compress-chunk-size = 65534
