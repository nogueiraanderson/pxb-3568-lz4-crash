[mysqld]
pxc_encrypt_cluster_traffic = OFF
innodb_buffer_pool_size      = 256M
innodb_log_file_size         = 128M
innodb_flush_log_at_trx_commit = 0

# Force xtrabackup-v2 SST method (default on PXC 8.0)
wsrep_sst_method = xtrabackup-v2

[sst]
encrypt = 0

[xtrabackup]
# This triggers the PXB-3568 crash: GCC 11/12 LTO generates an incorrect
# stride (36920 instead of 40) for std::vector element traversal in
# compress_write(). With _GLIBCXX_ASSERTIONS enabled (EL9 default), the
# corrupted bounds check fires on valid indices, causing Signal 6 (SIGABRT).
# See analysis/root-cause.md for the full analysis.
compress     = lz4
# 65534 = just under 64KB. Concurrent writes produce n_chunks > 1,
# which is required to hit the wrong stride on iteration >= 1.
compress-chunk-size = 65534
